<UserControl x:Class="SunlightPlugin.SunControlUI"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F5F5F5" Width="280">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="10">
            <Border Background="#1F2A44" CornerRadius="5" Padding="7,6" Margin="0,0,0,8">
                <StackPanel>
                    <TextBlock Name="txtAppTitle" Text="日照速算" Foreground="White" FontSize="13" FontWeight="Bold"/>
                    <TextBlock Name="txtAppVersion" Text="版本 1.2.0" Foreground="#C7D2FE" FontSize="10" Margin="0,1,0,0"/>
                </StackPanel>
            </Border>

            <GroupBox Header="1. 日照标准设置" Margin="0,0,0,10" FontWeight="Bold" BorderBrush="#CCCCCC">
                <StackPanel Margin="5">
                    <ComboBox Name="cmbDate" SelectedIndex="0" Margin="0,0,0,5">
                        <ComboBoxItem Content="大寒日 (1月20日 8:00-16:00)"/>
                        <ComboBoxItem Content="冬至日 (12月22日 9:00-15:00)"/>
                    </ComboBox>
                    <Grid Margin="0,0,0,5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <ComboBox Name="cmbProvince" Margin="0,0,2,0" SelectionChanged="cmbProvince_SelectionChanged" IsEditable="True" IsTextSearchEnabled="False" StaysOpenOnEdit="True" KeyUp="cmbProvince_KeyUp"/>
                        <ComboBox Name="cmbCity" Grid.Column="1" Margin="2,0,0,0" SelectionChanged="cmbCity_SelectionChanged" IsEditable="True" IsTextSearchEnabled="False" StaysOpenOnEdit="True" KeyUp="cmbCity_KeyUp"/>
                    </Grid>
                    <Grid Margin="0,0,0,5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="经度:" Foreground="#666666"/>
                            <TextBox Name="txtLongitude" Width="45" Margin="5,0,0,0" Text="121.47" IsReadOnly="True" Background="#EEEEEE"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center">
                            <TextBlock Text="纬度:" Foreground="#666666"/>
                            <TextBox Name="txtLatitude" Width="45" Margin="5,0,0,0" Text="31.23" IsReadOnly="True" Background="#EEEEEE"/>
                        </StackPanel>
                    </Grid>
                    <Grid Margin="0,0,0,5">
                        <TextBlock Text="计算步长(分钟):" VerticalAlignment="Center"/>
                        <TextBox Name="txtTimeStep" Width="60" HorizontalAlignment="Right" Text="5"/>
                    </Grid>
                </StackPanel>
            </GroupBox>

            <GroupBox Header="2. 建筑模型生成" Margin="0,0,0,10" FontWeight="Bold" BorderBrush="#CCCCCC">
                <StackPanel Margin="5">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <RadioButton Name="rbInputHeight" Content="总高" IsChecked="True" Margin="0,0,10,0" Checked="OnModeChanged"/>
                        <RadioButton Name="rbCalcHeight" Content="按层" Checked="OnModeChanged"/>
                    </StackPanel>
                    <StackPanel Name="panelTotalHeight" Visibility="Visible">
                        <Grid Margin="0,0,0,5">
                            <TextBlock Text="总高(m):"/>
                            <TextBox Name="txtTotalHeight" Width="60" HorizontalAlignment="Right" Text="54.0"/>
                        </Grid>
                    </StackPanel>
                    <StackPanel Name="panelCalcHeight" Visibility="Collapsed">
                        <Grid Margin="0,0,0,5">
                            <TextBlock Text="层数:"/>
                            <TextBox Name="txtFloors" Width="60" HorizontalAlignment="Right" Text="18"/>
                        </Grid>
                        <Grid Margin="0,0,0,5">
                            <TextBlock Text="标准层高(m):"/>
                            <TextBox Name="txtFloorHeight" Width="60" HorizontalAlignment="Right" Text="2.9"/>
                        </Grid>
                        <Grid Margin="0,0,0,5">
                            <TextBlock Text="室内外高差(m):"/>
                            <TextBox Name="txtElevationDiff" Width="60" HorizontalAlignment="Right" Text="0.3"/>
                        </Grid>
                        <Grid Margin="0,0,0,5">
                            <TextBlock Text="女儿墙高(m):"/>
                            <TextBox Name="txtParapet" Width="60" HorizontalAlignment="Right" Text="1.2"/>
                        </Grid>
                    </StackPanel>
                    <Button Name="btnPickOutline" Content="拾取轮廓生成模型" Height="30" Click="btnPickOutline_Click" Background="#007ACC" Foreground="White" BorderThickness="0"/>

                    <Button Name="btnImportTz" Content="导入天正日照对象(MVP)" Height="30" Background="#FD7E14" Foreground="White" BorderThickness="0" Margin="0,6,0,0" Click="btnImportTz_Click"/>
                </StackPanel>
            </GroupBox>

            <GroupBox Header="3. 核心推敲工作流" Margin="0,0,0,10" FontWeight="Bold" BorderBrush="#CCCCCC">
                <StackPanel Margin="5">
                    <Button Name="btnClear" Content="🧹 清理图面日照结果" Height="25" Background="#E2E3E5" Foreground="#333333" BorderThickness="0" Margin="0,0,0,10" Click="btnClear_Click"/>

                    <GroupBox Header="3.1 输入条件" Margin="0,0,0,8" BorderBrush="#D4D4D4">
                        <StackPanel Margin="5">
                            <Button Name="btnSetBoundary" Content="① 设定计算边界 (先选后执行)" Height="30" Background="#6C757D" Foreground="White" BorderThickness="0" Margin="0,0,0,2" Click="btnSetBoundary_Click"/>

                            <Grid Margin="0,5,0,5" Background="#E9ECEF">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="2">
                                    <TextBlock Text="面高(m):" FontSize="11" VerticalAlignment="Center"/>
                                    <TextBox Name="txtCalcHeight" Width="35" Margin="2,0,0,0" Text="0.9"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="2">
                                    <TextBlock Text="间距(m):" FontSize="11" VerticalAlignment="Center"/>
                                    <TextBox Name="txtGridSpacing" Width="35" Margin="2,0,0,0" Text="2.0"/>
                                </StackPanel>
                            </Grid>

                            <Button Name="btnSelectStatic" Content="② 录入现状楼栋 (先选后执行)" Height="30" Background="#6C757D" Foreground="White" BorderThickness="0" Margin="0,0,0,2" Click="btnSelectStatic_Click"/>
                            <TextBlock Name="txtStatus1" Text="等待设定..." Foreground="#888888" FontSize="11" Margin="0,0,0,2" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </GroupBox>

                    <GroupBox Header="3.2 测算" BorderBrush="#D4D4D4">
                        <StackPanel Margin="5">
                            <TabControl Name="tabCalcMode" Margin="0,0,0,8" SelectionChanged="tabCalcMode_SelectionChanged">
                                <TabItem Header="场地">
                                    <StackPanel Margin="6,6,6,4">
                                        <Button Name="btnStep2" Content="③ 平面网格测算" Height="30" Background="#17A2B8" Foreground="White" BorderThickness="0" Margin="0,0,0,4" Click="btnStep2_Click"/>
                                        <CheckBox Name="chkRealtimeMode" Content="启用原生命令实时联动 (MOVE/ROTATE)" IsChecked="False" Margin="0,0,0,2" Foreground="#2F4F4F" Checked="chkRealtimeMode_Checked" Unchecked="chkRealtimeMode_Checked"/>
                                    </StackPanel>
                                </TabItem>
                                <TabItem Header="立面">
                                    <StackPanel Margin="6,6,6,4">
                                        <TextBlock Text="立面网格测算（按间距，剔除北向±45°）" Foreground="#666666" FontSize="11" Margin="0,0,0,4" HorizontalAlignment="Center"/>
                                        <CheckBox Name="chkFacadeRealtime" Content="立面测算随 MOVE/ROTATE 自动刷新" IsChecked="False" Margin="0,0,0,4" Foreground="#2F4F4F" Checked="chkFacadeRealtime_Checked" Unchecked="chkFacadeRealtime_Checked"/>
                                        <Button Name="btnFacadeCalc" Content="③ 立面网格测算（多体块）" Height="30" Background="#0D6EFD" Foreground="White" BorderThickness="0" Margin="0,0,0,2" Click="btnFacadeCalc_Click"/>
                                    </StackPanel>
                                </TabItem>
                            </TabControl>

                            <TextBlock Name="txtStatus2" Text="未计算缓存" Foreground="#888888" FontSize="11" Margin="0,0,0,8" HorizontalAlignment="Center"/>

                            <ToggleButton Name="btnStep3" Content="④ 启动共用推敲 (场地/立面)" Height="35" Background="#28A745" Foreground="White" FontWeight="Bold" BorderThickness="0" Click="btnStep3_Click"/>
                        </StackPanel>
                    </GroupBox>
                </StackPanel>
            </GroupBox>
        </StackPanel>
    </ScrollViewer>
</UserControl>